  <entry>
    <title>一篇新的小文，庆祝升级1.2.0的成功</title>
    <link href="https://bg4vrg.com/2023/03/06/%E4%B8%80%E7%AF%87%E6%96%B0%E7%9A%84%E5%B0%8F%E6%96%87%EF%BC%8C%E5%BA%86%E7%A5%9D%E5%8D%87%E7%BA%A71.2.0%E7%9A%84%E6%88%90%E5%8A%9F/"/>
    <id>https://bg4vrg.com/2023/03/06/%E4%B8%80%E7%AF%87%E6%96%B0%E7%9A%84%E5%B0%8F%E6%96%87%EF%BC%8C%E5%BA%86%E7%A5%9D%E5%8D%87%E7%BA%A71.2.0%E7%9A%84%E6%88%90%E5%8A%9F/</id>
    <published>2023-03-05T16:00:00.000Z</published>
    <updated>2024-02-17T06:58:28.893Z</updated>
    
